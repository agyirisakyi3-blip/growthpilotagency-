generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String
  company   String
  phone     String
  website   String   @default("")
  message   String   @default("")
  status    String   @default("new")
  source    String   @default("website")
  createdAt DateTime @default(now())

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String   @default("website")
  createdAt DateTime @default(now())

  @@index([email])
  @@index([createdAt])
}

model EmailLog {
  id        String   @id @default(cuid())
  recipient String
  subject   String
  type      String
  status    String   @default("sent")
  error     String?
  createdAt DateTime @default(now())

  @@index([recipient])
  @@index([type])
  @@index([createdAt])
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String
  subject   String
  message   String
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String   @unique
  token     String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([email])
}

model BlogPost {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  excerpt   String
  content   String
  category  String
  image     String   @default("/blog/default.jpg")
  author    String   @default("Agyiri Sakyi")
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([category])
  @@index([published])
  @@index([createdAt])
}

model CaseStudy {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  client    String
  industry  String
  challenge String
  solution  String
  results   String
  metrics   String   @default("{}")
  image     String   @default("/cases/default.jpg")
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([published])
}
